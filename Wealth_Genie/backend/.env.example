# Supabase credentials (obtain from your Supabase Project Settings API tab)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
PORT=8000

# --- Milestone 3: Universal Financial Extractor ---
# Provider-independent: switch LLM_PROVIDER to swap the structuring engine
# without touching any extraction code (see app/services/llm/factory.py).
LLM_PROVIDER=claude
ANTHROPIC_API_KEY=your-anthropic-api-key
LLM_MODEL=claude-sonnet-4-6

# Below this many extracted characters (sampled over the first 3 pages), a
# PDF is classified as scanned and routed through OCR instead of direct text
# extraction.
OCR_TEXT_THRESHOLD_CHARS=50
MAX_OCR_PAGES=15
